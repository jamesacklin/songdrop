# slskd auth: EITHER an API key (Options > Web > Authentication > API keys)...
SLSKD_API_KEY=
# ...OR the slskd web UI username/password:
SLSKD_USERNAME=
SLSKD_PASSWORD=

# Access key the app/PWA uses to reach Songdrop. OPTIONAL: leave blank and
# the server generates one on first boot and prints it to the logs (persisted in
# /data). Set a value here to pin your own.
SONGDROP_API_KEY=

# Absolute path (on the host) to the music folder your Plex library points at.
MUSIC_LIBRARY_PATH=/path/to/plex/Music

# Plex (leave empty to skip the Plex scan/playlist steps)
PLEX_URL=http://192.168.1.10:32400
PLEX_TOKEN=
PLEX_SECTION=Music

# Optional: ntfy topic for "your track is ready" push notifications
# NTFY_URL=https://ntfy.sh/your-secret-topic
